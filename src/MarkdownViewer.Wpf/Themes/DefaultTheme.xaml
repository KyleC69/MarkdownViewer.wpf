<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="ViewerBackgroundBrush" Color="#FFFDFEFF" />
    <SolidColorBrush x:Key="ViewerBorderBrush" Color="#FFD9E2F0" />
    <Thickness x:Key="ViewerBorderThickness">1</Thickness>

    <Style TargetType="StackPanel" x:Key="RootPanelStyle">
        <Setter Property="Margin" Value="0" />
    </Style>

    <Style TargetType="TextBlock" x:Key="ParagraphStyle">
        <Setter Property="Margin" Value="0,0,0,12" />
        <Setter Property="Foreground" Value="#172033" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="LineHeight" Value="21" />
    </Style>

    <Style TargetType="TextBlock" x:Key="Heading1Style" BasedOn="{StaticResource ParagraphStyle}">
        <Setter Property="FontSize" Value="30" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Margin" Value="0,8,0,16" />
    </Style>
    <Style TargetType="TextBlock" x:Key="Heading2Style" BasedOn="{StaticResource ParagraphStyle}">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Margin" Value="0,8,0,14" />
    </Style>
    <Style TargetType="TextBlock" x:Key="Heading3Style" BasedOn="{StaticResource ParagraphStyle}">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,6,0,12" />
    </Style>
    <Style TargetType="TextBlock" x:Key="Heading4Style" BasedOn="{StaticResource ParagraphStyle}">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,6,0,10" />
    </Style>
    <Style TargetType="TextBlock" x:Key="Heading5Style" BasedOn="{StaticResource ParagraphStyle}">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style TargetType="TextBlock" x:Key="Heading6Style" BasedOn="{StaticResource ParagraphStyle}">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style TargetType="StackPanel" x:Key="ListStyle">
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>
    <Style TargetType="Grid" x:Key="ListItemContainerStyle">
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>
    <Style TargetType="TextBlock" x:Key="ListItemMarkerStyle" BasedOn="{StaticResource ParagraphStyle}">
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,10,0" />
        <Setter Property="VerticalAlignment" Value="Top" />
    </Style>
    <Style TargetType="StackPanel" x:Key="ListItemContentStyle">
        <Setter Property="Margin" Value="0" />
    </Style>

    <Style TargetType="Border" x:Key="BlockQuoteBorderStyle">
        <Setter Property="BorderBrush" Value="#7F95BC" />
        <Setter Property="BorderThickness" Value="4,0,0,0" />
        <Setter Property="Padding" Value="16,6,12,6" />
        <Setter Property="Margin" Value="0,0,0,12" />
        <Setter Property="Background" Value="#FFF5F8FD" />
        <Setter Property="CornerRadius" Value="0,10,10,0" />
    </Style>

    <Style TargetType="Border" x:Key="CodeBlockBorderStyle">
        <Setter Property="Background" Value="#FF0F1728" />
        <Setter Property="BorderBrush" Value="#FF223552" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>
    <Style TargetType="DockPanel" x:Key="CodeBlockHeaderPanelStyle">
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="LastChildFill" Value="False" />
    </Style>
    <Style TargetType="TextBlock" x:Key="CodeBlockHeaderTextStyle">
        <Setter Property="Foreground" Value="#FFC3D2F1" />
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style TargetType="TextBlock" x:Key="CodeBlockTextStyle">
        <Setter Property="Foreground" Value="#FFF2F6FF" />
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="FontSize" Value="13" />
    </Style>
    <Style TargetType="Button" x:Key="CodeBlockCopyButtonStyle">
        <Setter Property="Padding" Value="12,5" />
        <Setter Property="Margin" Value="8,0,0,0" />
        <Setter Property="Background" Value="#FF294B7A" />
        <Setter Property="BorderBrush" Value="#FF4A6796" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#FF345C93" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#FF203D63" />
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style TargetType="ScrollViewer" x:Key="CodeBlockScrollViewerStyle">
        <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style TargetType="Run" x:Key="CodeInlineStyle">
        <Setter Property="Background" Value="#FFE9EEF8" />
        <Setter Property="Foreground" Value="#FF223552" />
        <Setter Property="FontFamily" Value="Consolas" />
    </Style>

    <Style TargetType="Hyperlink" x:Key="HyperlinkStyle">
        <Setter Property="Foreground" Value="#005DB3" />
        <Setter Property="TextDecorations" Value="Underline" />
    </Style>
    <Style TargetType="Image" x:Key="ImageStyle">
        <Setter Property="MaxWidth" Value="720" />
    </Style>
    <Style TargetType="TextBlock" x:Key="HtmlBlockStyle" BasedOn="{StaticResource ParagraphStyle}">
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="Background" Value="#FFF4F7FB" />
        <Setter Property="Padding" Value="10" />
    </Style>

    <Style TargetType="Grid" x:Key="TableStyle">
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>
    <Style TargetType="Border" x:Key="TableCellBorderStyle">
        <Setter Property="BorderBrush" Value="#FFD2DBE9" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="Background" Value="#FFFFFFFF" />
    </Style>
    <Style TargetType="Border" x:Key="TableHeaderCellBorderStyle" BasedOn="{StaticResource TableCellBorderStyle}">
        <Setter Property="Background" Value="#FFEAF0FA" />
    </Style>

    <Style TargetType="CheckBox" x:Key="TaskListCheckBoxStyle">
        <Setter Property="Margin" Value="0,0,4,-2" />
    </Style>
    <Style TargetType="Border" x:Key="ThematicBreakStyle">
        <Setter Property="Background" Value="#FFD0DAE8" />
        <Setter Property="Margin" Value="0,4,0,16" />
    </Style>

    <Style TargetType="Span" x:Key="StrikeThroughStyle">
        <Setter Property="TextBlock.TextDecorations" Value="Strikethrough" />
    </Style>
    <Style TargetType="Span" x:Key="SubscriptStyle">
        <Setter Property="Typography.Variants" Value="Subscript" />
    </Style>
    <Style TargetType="Span" x:Key="SuperscriptStyle">
        <Setter Property="Typography.Variants" Value="Superscript" />
    </Style>
    <Style TargetType="Span" x:Key="InsertedStyle">
        <Setter Property="TextBlock.TextDecorations" Value="Underline" />
    </Style>
    <Style TargetType="Span" x:Key="MarkedStyle">
        <Setter Property="Background" Value="#FFF3A8" />
    </Style>

    <SolidColorBrush x:Key="DiagnosticsOverlayBorderBrush" Color="#FFFF5A36" />
    <Thickness x:Key="DiagnosticsOverlayBorderThickness">1</Thickness>
    <Style TargetType="Border" x:Key="DiagnosticsLabelBorderStyle">
        <Setter Property="Background" Value="#FFF4C94C" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="4,1,4,1" />
        <Setter Property="Margin" Value="4" />
    </Style>
    <Style TargetType="TextBlock" x:Key="DiagnosticsLabelTextStyle">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#111111" />
    </Style>
</ResourceDictionary>