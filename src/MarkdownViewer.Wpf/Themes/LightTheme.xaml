<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:MarkdownViewer.Wpf"
                    xmlns:theming="clr-namespace:MarkdownViewer.Wpf.Theming">
    <SolidColorBrush x:Key="ViewerBackgroundBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="ViewerBorderBrush" Color="#FFE2E8F2" />
    <Thickness x:Key="ViewerBorderThickness">1</Thickness>

    <Style TargetType="{x:Type controls:MarkdownView}">
        <Setter Property="Background" Value="#FFFFFFFF" />
        <Setter Property="BorderBrush" Value="#FFE2E8F2" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Margin" Value="0,0,0,12" />
        <Setter Property="Foreground" Value="#FF152238" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="LineHeight" Value="21" />
        <Style.Triggers>
            <Trigger Property="theming:MarkdownTheming.Role" Value="Heading1Style">
                <Setter Property="FontSize" Value="30" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Margin" Value="0,8,0,16" />
            </Trigger>
            <Trigger Property="theming:MarkdownTheming.Role" Value="Heading2Style">
                <Setter Property="FontSize" Value="24" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Margin" Value="0,8,0,14" />
            </Trigger>
            <Trigger Property="theming:MarkdownTheming.Role" Value="Heading3Style">
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,6,0,12" />
            </Trigger>
            <Trigger Property="theming:MarkdownTheming.Role" Value="Heading4Style">
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,6,0,10" />
            </Trigger>
            <Trigger Property="theming:MarkdownTheming.Role" Value="Heading5Style">
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Trigger>
            <Trigger Property="theming:MarkdownTheming.Role" Value="Heading6Style">
                <Setter Property="FontSize" Value="15" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Trigger>
            <Trigger Property="theming:MarkdownTheming.Role" Value="ListItemMarkerStyle">
                <Setter Property="Foreground" Value="#FF255AAE" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,0,10,0" />
                <Setter Property="VerticalAlignment" Value="Top" />
            </Trigger>
            <Trigger Property="theming:MarkdownTheming.Role" Value="CodeBlockHeaderTextStyle">
                <Setter Property="Margin" Value="0" />
                <Setter Property="Foreground" Value="#FFD2DFF5" />
                <Setter Property="FontFamily" Value="Consolas" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Trigger>
            <Trigger Property="theming:MarkdownTheming.Role" Value="CodeBlockTextStyle">
                <Setter Property="Margin" Value="0" />
                <Setter Property="Foreground" Value="#FFF5F8FF" />
                <Setter Property="FontFamily" Value="Consolas" />
                <Setter Property="FontSize" Value="13" />
            </Trigger>
            <Trigger Property="theming:MarkdownTheming.Role" Value="HtmlBlockStyle">
                <Setter Property="FontFamily" Value="Consolas" />
                <Setter Property="Background" Value="#FFF4F8FC" />
                <Setter Property="Padding" Value="10" />
            </Trigger>
            <Trigger Property="theming:MarkdownTheming.Role" Value="DiagnosticsLabelTextStyle">
                <Setter Property="Margin" Value="0" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="#FF111111" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="StackPanel">
        <Setter Property="Margin" Value="0" />
        <Style.Triggers>
            <Trigger Property="theming:MarkdownTheming.Role" Value="ListStyle">
                <Setter Property="Margin" Value="0,0,0,12" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="Grid">
        <Style.Triggers>
            <Trigger Property="theming:MarkdownTheming.Role" Value="ListItemContainerStyle">
                <Setter Property="Margin" Value="0,0,0,6" />
            </Trigger>
            <Trigger Property="theming:MarkdownTheming.Role" Value="TableStyle">
                <Setter Property="Margin" Value="0,0,0,12" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="Border">
        <Style.Triggers>
            <Trigger Property="theming:MarkdownTheming.Role" Value="BlockQuoteBorderStyle">
                <Setter Property="BorderBrush" Value="#FF78A3DD" />
                <Setter Property="BorderThickness" Value="4,0,0,0" />
                <Setter Property="Padding" Value="16,6,12,6" />
                <Setter Property="Margin" Value="0,0,0,12" />
                <Setter Property="Background" Value="#FFF3F8FF" />
                <Setter Property="CornerRadius" Value="0,10,10,0" />
            </Trigger>
            <Trigger Property="theming:MarkdownTheming.Role" Value="CodeBlockBorderStyle">
                <Setter Property="Background" Value="#FF132033" />
                <Setter Property="BorderBrush" Value="#FF2C4568" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="12" />
                <Setter Property="Margin" Value="0,0,0,12" />
            </Trigger>
            <Trigger Property="theming:MarkdownTheming.Role" Value="TableCellBorderStyle">
                <Setter Property="BorderBrush" Value="#FFD7DFEC" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="10,8" />
                <Setter Property="Background" Value="#FFFFFFFF" />
            </Trigger>
            <Trigger Property="theming:MarkdownTheming.Role" Value="TableHeaderCellBorderStyle">
                <Setter Property="BorderBrush" Value="#FFD7DFEC" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="10,8" />
                <Setter Property="Background" Value="#FFEEF4FB" />
            </Trigger>
            <Trigger Property="theming:MarkdownTheming.Role" Value="ThematicBreakStyle">
                <Setter Property="Background" Value="#FFD7E0EC" />
                <Setter Property="Margin" Value="0,4,0,16" />
            </Trigger>
            <Trigger Property="theming:MarkdownTheming.Role" Value="DiagnosticsLabelBorderStyle">
                <Setter Property="Background" Value="#FFFFDE87" />
                <Setter Property="CornerRadius" Value="2" />
                <Setter Property="Padding" Value="4,1,4,1" />
                <Setter Property="Margin" Value="4" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DockPanel">
        <Style.Triggers>
            <Trigger Property="theming:MarkdownTheming.Role" Value="CodeBlockHeaderPanelStyle">
                <Setter Property="Margin" Value="0,0,0,10" />
                <Setter Property="LastChildFill" Value="False" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="Button">
        <Style.Triggers>
            <Trigger Property="theming:MarkdownTheming.Role" Value="CodeBlockCopyButtonStyle">
                <Setter Property="Padding" Value="12,5" />
                <Setter Property="Margin" Value="8,0,0,0" />
                <Setter Property="Background" Value="#FF3360A4" />
                <Setter Property="BorderBrush" Value="#FF5781C1" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Foreground" Value="#FFFFFFFF" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="theming:MarkdownTheming.Role" Value="CodeBlockCopyButtonStyle" />
                    <Condition Property="IsMouseOver" Value="True" />
                </MultiTrigger.Conditions>
                <Setter Property="Background" Value="#FF4272BD" />
            </MultiTrigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="theming:MarkdownTheming.Role" Value="CodeBlockCopyButtonStyle" />
                    <Condition Property="IsPressed" Value="True" />
                </MultiTrigger.Conditions>
                <Setter Property="Background" Value="#FF264A7F" />
            </MultiTrigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ScrollViewer">
        <Style.Triggers>
            <Trigger Property="theming:MarkdownTheming.Role" Value="CodeBlockScrollViewerStyle">
                <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
                <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
                <Setter Property="Background" Value="Transparent" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="Run">
        <Style.Triggers>
            <Trigger Property="theming:MarkdownTheming.Role" Value="CodeInlineStyle">
                <Setter Property="Background" Value="#FFEAF0F8" />
                <Setter Property="Foreground" Value="#FF20324D" />
                <Setter Property="FontFamily" Value="Consolas" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="Hyperlink">
        <Setter Property="Foreground" Value="#FF135BB8" />
        <Setter Property="TextDecorations" Value="Underline" />
    </Style>
    <Style TargetType="Image">
        <Setter Property="MaxWidth" Value="720" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Margin" Value="0,0,4,-2" />
        <Setter Property="Foreground" Value="#FF152238" />
    </Style>
    <Style TargetType="Span">
        <Style.Triggers>
            <Trigger Property="theming:MarkdownTheming.Role" Value="StrikeThroughStyle">
                <Setter Property="TextBlock.TextDecorations" Value="Strikethrough" />
            </Trigger>
            <Trigger Property="theming:MarkdownTheming.Role" Value="SubscriptStyle">
                <Setter Property="Typography.Variants" Value="Subscript" />
            </Trigger>
            <Trigger Property="theming:MarkdownTheming.Role" Value="SuperscriptStyle">
                <Setter Property="Typography.Variants" Value="Superscript" />
            </Trigger>
            <Trigger Property="theming:MarkdownTheming.Role" Value="InsertedStyle">
                <Setter Property="TextBlock.TextDecorations" Value="Underline" />
            </Trigger>
            <Trigger Property="theming:MarkdownTheming.Role" Value="MarkedStyle">
                <Setter Property="Background" Value="#FFFFF0AA" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <SolidColorBrush x:Key="DiagnosticsOverlayBorderBrush" Color="#FFFF6C43" />
    <Thickness x:Key="DiagnosticsOverlayBorderThickness">1</Thickness>
</ResourceDictionary>