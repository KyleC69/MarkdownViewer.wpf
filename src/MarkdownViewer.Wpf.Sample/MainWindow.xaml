<Window x:Class="MarkdownViewer.Wpf.Sample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:markdown="clr-namespace:MarkdownViewer.Wpf;assembly=MarkdownViewer.Wpf"
        mc:Ignorable="d"
        Title="MarkdownViewer.Wpf Sample"
        Width="1480"
        Height="920"
        MinWidth="1100"
        MinHeight="700"
        Background="#F3F6FB">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,16"
                Padding="20"
                Background="#0F172A"
                CornerRadius="20">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Foreground="White"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Text="MarkdownViewer.Wpf" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#B7C5E0"
                               FontSize="14"
                               Text="Editable markdown on the left, themed live preview on the right." />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Margin="0,0,10,0"
                               VerticalAlignment="Center"
                               Foreground="#D8E2F2"
                               FontWeight="SemiBold"
                               Text="Theme" />
                    <ComboBox Width="170"
                              Margin="0,0,12,0"
                              ItemsSource="{Binding ThemeOptions}"
                              SelectedItem="{Binding SelectedThemeKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Padding="14,8"
                            Background="#2D6AE3"
                            Foreground="White"
                            BorderBrush="#2D6AE3"
                            FontWeight="SemiBold"
                            Click="ReloadSampleMarkdown_Click"
                            Content="Reload Sample" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="0.95*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="18"
                    Background="White"
                    BorderBrush="#D9E2F0"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Margin="0,0,0,12">
                        <TextBlock FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#13203A"
                                   Text="Markdown Source" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="#52627F"
                                   Text="Edit the bundled sample markdown to watch the control rerender in place." />
                    </StackPanel>

                    <TextBox Grid.Row="1"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="14"
                             TextWrapping="NoWrap"
                             Text="{Binding MarkdownText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Padding="18"
                    Background="#FBFCFE"
                    BorderBrush="#D9E2F0"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Margin="0,0,0,12">
                        <TextBlock FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#13203A"
                                   Text="Rendered Preview" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="#52627F"
                                   Text="The preview uses the current theme through the public MarkdownView API." />
                    </StackPanel>

                    <Border Grid.Row="1"
                            Background="White"
                            BorderBrush="#E1E8F4"
                            BorderThickness="1"
                            CornerRadius="14">
                        <markdown:MarkdownView Markdown="{Binding MarkdownText}"
                                               Theme="{Binding CurrentTheme}"
                                               Padding="20" />
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>